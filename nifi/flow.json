          "schedulingPeriod": "0 sec",
          "maxConcurrentTasks": 1,
          "penaltyDuration": "30 sec",
          "yieldDuration": "1 sec",
          "bulletinLevel": "WARN",
          "runDurationMillis": 0,
          "relationships": [
            { "name": "success", "autoTerminate": true }
