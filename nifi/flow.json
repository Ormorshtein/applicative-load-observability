          "penaltyDuration": "30 sec",
          "yieldDuration": "1 sec",
          "bulletinLevel": "WARN",
          "runDurationMillis": 0,
          "relationships": [
            { "name": "success",  "autoTerminate": true  },
            { "name": "retry",    "autoTerminate": false },
            { "name": "failure",  "autoTerminate": false }
