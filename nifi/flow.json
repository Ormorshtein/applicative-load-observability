        },
        {
          "identifier": "retry-es-write",
          "name": "RetryFlowFile — ES write retry",
          "type": "org.apache.nifi.processors.standard.RetryFlowFile",
          "bundle": {
            "group": "org.apache.nifi",
            "artifact": "nifi-standard-nar",
            "version": "2.0.0"
          },
          "position": { "x": 900.0, "y": 400.0 },
          "properties": {
            "retry-attribute": "flowfile.retries",
            "maximum-retries": "5",
            "penalize-retried": "true",
            "fail-on-non-integer-value": "true"
