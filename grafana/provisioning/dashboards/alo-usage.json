{
  "uid": "alo-usage",
  "title": "ALO — Cluster Usage",
  "description": "Request rates, latency percentiles, error tracking, and data volume analytics.",
  "tags": [
    "alo",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rates",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 2
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "mode": "markdown",
        "content": "### Request Rates"
      }
    },
    {
      "id": 2,
      "title": "Total Request Rate",
      "type": "timeseries",
      "datasource": {
        "type": "elasticsearch",
        "uid": "alo-elasticsearch"
      },
      "gridPos": {
        "x": 0,
        "y": 2,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "elasticsearch",
            "uid": "alo-elasticsearch"
          },
          "query": "cluster_name:(${cluster:lucene}) AND identity.applicative_provider:(${application:lucene}) AND request.target:(${target:lucene}) AND request.operation:(${operation:lucene}) AND identity.username:(${username:lucene}) AND stress.cost_indicator_names:(${cost_indicator:lucene}) AND identity.client_host:(${client_host:lucene}) AND request.template:(${template:lucene})",
          "refId": "A",
          "metrics": [
            {
              "type": "count",
              "id": "1"
            }
          ],
          "bucketAggs": [
            {
              "type": "date_histogram",
              "field": "@timestamp",
              "id": "2",
              "settings": {
                "interval": "auto"
              }
            }
          ],
          "alias": "Requests"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0
          }
        },
        "overrides": []
      }
    },
