{
  "uid": "alo-health",
  "title": "ALO — Stack Health",
  "description": "Operational health of the ALO pipeline: gateway, analyzer, and logstash.",
  "tags": [
    "alo",
    "health",
    "prometheus"
  ],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "schemaVersion": 39,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "gateway_instance",
        "label": "Gateway",
        "type": "query",
        "datasource": {
          "uid": "alo-prometheus",
          "type": "prometheus"
        },
        "definition": "label_values(nginx_up, instance)",
        "query": "label_values(nginx_up, instance)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      },
      {
        "name": "analyzer_instance",
        "label": "Analyzer",
        "type": "query",
        "datasource": {
          "uid": "alo-prometheus",
          "type": "prometheus"
        },
        "definition": "label_values(http_requests_total{job=\"analyzer\"}, instance)",
        "query": "label_values(http_requests_total{job=\"analyzer\"}, instance)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      },
      {
        "name": "logstash_instance",
        "label": "Logstash",
        "type": "query",
        "datasource": {
          "uid": "alo-prometheus",
          "type": "prometheus"
        },
        "definition": "label_values(logstash_info_up, instance)",
        "query": "label_values(logstash_info_up, instance)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      },
      {
        "type": "query",
        "name": "es_instance",
        "label": "ES Instance",
        "datasource": {
          "uid": "alo-prometheus",
          "type": "prometheus"
        },
        "query": "label_values(elasticsearch_process_cpu_percent, instance)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Gateway (Nginx)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Gateways UP",
      "description": "Number of healthy gateway instances over time. A drop means instances went down.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "total"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "white",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "count(nginx_up{instance=~\"$gateway_instance\"} == 1)",
          "legendFormat": "up",
          "refId": "A"
        },
        {
          "expr": "count(nginx_up{instance=~\"$gateway_instance\"})",
          "legendFormat": "total",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total{instance=~\"$gateway_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} total req/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connection States",
      "description": "Aggregated across selected instances. High 'reading' may indicate slow clients; high 'writing' may indicate slow upstream.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal"
            },
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nginx_connections_reading{instance=~\"$gateway_instance\"}",
          "legendFormat": "{{instance}} reading",
          "refId": "A"
        },
        {
          "expr": "nginx_connections_writing{instance=~\"$gateway_instance\"}",
          "legendFormat": "{{instance}} writing",
          "refId": "B"
        },
        {
          "expr": "nginx_connections_waiting{instance=~\"$gateway_instance\"}",
          "legendFormat": "{{instance}} waiting",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Dropped Connections",
      "description": "Sum of (accepted - handled) across all instances. Should always be zero. Non-zero means worker_connections limit was hit on one or more instances.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(nginx_connections_accepted{instance=~\"$gateway_instance\"}[$__rate_interval]) - rate(nginx_connections_handled{instance=~\"$gateway_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} dropped/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Analyzer (FastAPI)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{handler=\"/analyze\",instance=~\"$analyzer_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} analyze req/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "description": "Percentage of non-2xx responses on /analyze. The analyzer is designed to always return 200 — any errors here indicate a real issue.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{handler=\"/analyze\",instance=~\"$analyzer_instance\",status=~\"4xx\"}[$__rate_interval])) / sum(rate(http_requests_total{handler=\"/analyze\",instance=~\"$analyzer_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} 4xx %",
          "refId": "A"
        },
        {
          "expr": "rate(http_requests_total{handler=\"/analyze\",instance=~\"$analyzer_instance\",status=~\"5xx\"}[$__rate_interval])) / sum(rate(http_requests_total{handler=\"/analyze\",instance=~\"$analyzer_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} 5xx %",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency (P50 / P95 / P99)",
      "description": "Request duration percentiles aggregated across selected instances.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_highr_seconds_bucket{instance=~\"$analyzer_instance\"}[$__rate_interval])) by (le, instance))",
          "legendFormat": "{{instance}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket{instance=~\"$analyzer_instance\"}[$__rate_interval])) by (le, instance))",
          "legendFormat": "{{instance}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_highr_seconds_bucket{instance=~\"$analyzer_instance\"}[$__rate_interval])) by (le, instance))",
          "legendFormat": "{{instance}} p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "description": "Analyzer process CPU usage per instance.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"analyzer\",instance=~\"$analyzer_instance\"}[$__rate_interval]) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "description": "Analyzer process resident memory",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "uid": "alo-prometheus",
            "type": "prometheus"
          },
          "expr": "process_resident_memory_bytes{instance=~\"$analyzer_instance\",job=\"analyzer\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "type": "row",
      "title": "Logstash Pipeline",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Events In / Out Rate",
      "description": "Aggregated throughput. Output should track input; a growing gap means events are backing up.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "logstash_stats_flow_input_current{instance=~\"$logstash_instance\"}",
          "legendFormat": "{{instance}} events in/s",
          "refId": "A"
        },
        {
          "expr": "logstash_stats_flow_output_current{instance=~\"$logstash_instance\"}",
          "legendFormat": "{{instance}} events out/s",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "description": "Logstash process CPU utilization",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "uid": "alo-prometheus",
            "type": "prometheus"
          },
          "expr": "logstash_stats_process_cpu_percent{instance=~\"$analyzer_instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Queue Backpressure",
      "description": "Pipeline queue backpressure flow metric",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "uid": "alo-prometheus",
            "type": "prometheus"
          },
          "expr": "logstash_stats_flow_queue_backpressure_current{instance=~\"$logstash_instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Output Errors",
      "description": "Elasticsearch bulk request errors and non-retryable document failures. Any sustained growth means data loss.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 35,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(logstash_stats_pipeline_plugin_bulk_requests_errors{instance=~\"$logstash_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} bulk errors/s",
          "refId": "A"
        },
        {
          "expr": "rate(logstash_stats_pipeline_plugin_documents_non_retryable_failures{instance=~\"$logstash_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} non-retryable/s",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Usage",
      "description": "Logstash JVM heap used vs max over time",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 43,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "uid": "alo-prometheus",
            "type": "prometheus"
          },
          "expr": "logstash_stats_jvm_mem_heap_used_bytes{instance=~\"$logstash_instance\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "datasource": {
            "uid": "alo-prometheus",
            "type": "prometheus"
          },
          "expr": "logstash_stats_jvm_mem_heap_max_bytes{instance=~\"$logstash_instance\"}",
          "legendFormat": "Max",
          "refId": "B"
        },
        {
          "datasource": {
            "uid": "alo-prometheus",
            "type": "prometheus"
          },
          "expr": "logstash_stats_jvm_mem_heap_committed_bytes{instance=~\"$logstash_instance\"}",
          "legendFormat": "Committed",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "JVM Non-Heap Memory",
      "description": "Logstash non-heap memory (class metadata, code cache)",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 43,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "uid": "alo-prometheus",
            "type": "prometheus"
          },
          "expr": "logstash_stats_jvm_mem_non_heap_committed_bytes{instance=~\"$logstash_instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Process Memory (Virtual)",
      "description": "Logstash total virtual memory",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 51,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "uid": "alo-prometheus",
            "type": "prometheus"
          },
          "expr": "logstash_stats_process_mem_total_virtual{instance=~\"$analyzer_instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GC Pressure",
      "description": "Old-gen GC time rate — the #1 cause of Logstash freezes. If old GC runs >5% of wall time, the pipeline is in trouble.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 51,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(logstash_stats_jvm_gc_collection_time_millis_total{type=\"old\",instance=~\"$logstash_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} old gc ms/s",
          "refId": "A"
        },
        {
          "expr": "rate(logstash_stats_jvm_gc_collection_time_millis_total{type=\"young\",instance=~\"$logstash_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} young gc ms/s",
          "refId": "B"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Avg Worker Utilization",
      "description": "Average worker utilization across selected instances. Near 100% = saturated.",
      "datasource": {
        "uid": "alo-prometheus",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 59,
