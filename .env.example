# ── Container-to-container (Docker Compose / Helm) ──────────────────────
# Set in docker-compose.yml with container-hostname defaults.
# Override when deploying to non-Docker environments.

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_HOST=elasticsearch:9200
ANALYZER_URL=http://analyzer:8000/analyze
LOGSTASH_URL=http://logstash:8080/
LOGSTASH_HTTP_PORT=8080
GATEWAY_PORT=9200
DNS_RESOLVER=127.0.0.11
CLUSTER_NAME=default

# ── Gateway ─────────────────────────────────────────────────────────────
# WORKER_PROCESSES=auto          # nginx worker_processes (default: auto)
# WORKER_CONNECTIONS=4096        # connections per worker
# LOGSTASH_TIMEOUT_MS=1000       # async notification timeout to Logstash

# ── Analyzer: stress baselines ──────────────────────────────────────────
# Static defaults used when ES is unreachable for dynamic baselines.
# STRESS_BASELINE_TOOK_MS=100
# STRESS_BASELINE_HITS=500
# STRESS_BASELINE_SHARDS_TOTAL=5
# STRESS_BASELINE_DOCS_AFFECTED=500

# ── Analyzer: dynamic baselines ─────────────────────────────────────────
# BASELINE_CACHE_TTL=60          # seconds between ES baseline refreshes
# BASELINE_QUERY_WINDOW=1h       # time window for P50 baseline queries

# ── Analyzer: cost indicator thresholds ──────────────────────────────────
# COST_INDICATOR_BOOL_THRESHOLD=50
# COST_INDICATOR_TERMS_THRESHOLD=500
# COST_INDICATOR_AGGS_THRESHOLD=10

# ── Analyzer: stress formula tuning ─────────────────────────────────────
# STRESS_CLAUSE_THRESHOLD=4
# STRESS_CLAUSE_WEIGHT=0.10
# STRESS_CLAUSE_CAP=0.50

# ── Auth / TLS (all components) ──────────────────────────────────────────
# ES_USERNAME=
# ES_PASSWORD=
# ES_CA_CERT=
# ES_INSECURE=false

# ── Host-side scripts (setup.py, stress.py) ──────────────────────────────
# These default to localhost when unset, which is correct for local dev.
# KIBANA_URL=http://localhost:5601
# ELASTICSEARCH_URL=http://localhost:9200
# GATEWAY_URL=http://localhost:9200
# GRAFANA_URL=http://localhost:3000
# GRAFANA_ADMIN_PASSWORD=admin
