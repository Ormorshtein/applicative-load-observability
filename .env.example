# ---- Container-to-container (used inside Docker / Helm) ----
# These are set in docker-compose.yml with container-hostname defaults.
# Override them when deploying to non-Docker environments.

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_HOST=elasticsearch:9200
ANALYZER_URL=http://analyzer:8000/analyze
LOGSTASH_URL=http://logstash:8080/
LOGSTASH_HTTP_PORT=8080
GATEWAY_PORT=9200
DNS_RESOLVER=127.0.0.11
LOGSTASH_MONITORING=false

# ---- Host-side scripts (setup.py, tools/stress/stress.py) ----
# These default to localhost when unset, which is correct for local dev.
# Set them when running scripts against a remote deployment.

# KIBANA_URL=http://localhost:5601
# ELASTICSEARCH_URL=http://localhost:9200
# GATEWAY_URL=http://localhost:9200
