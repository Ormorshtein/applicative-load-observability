{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clusterName": { "type": "string", "minLength": 1 },
        "observabilityIndex": { "type": "string", "minLength": 1 }
      },
      "required": ["clusterName"]
    },
    "tableSettings": {
      "type": "object",
      "additionalProperties": false,
      "description": "ClickHouse retention + partitioning passed to ch-setup.",
      "properties": {
        "rawRetentionDays": { "type": "integer", "minimum": 1 },
        "summaryRetentionDays": { "type": "integer", "minimum": 1 },
        "rawPartitionBy": { "type": "string" },
        "summaryPartitionBy": { "type": "string" }
      }
    },
    "clickhouse": {
      "type": "object",
      "additionalProperties": false,
      "description": "ClickHouse analytics sink (replaces v1's Elasticsearch sink).",
      "properties": {
        "enabled": { "type": "boolean" },
        "database": { "type": "string", "minLength": 1 },
        "external": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "url": { "type": "string" },
            "host": { "type": "string" },
            "auth": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "username": { "type": "string" },
                "password": { "type": "string" },
                "existingSecret": { "type": "string" }
              }
            },
            "tls": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "caCert": { "type": "string" },
                "caCertSecret": { "type": "string" },
                "create": { "type": "boolean" },
                "insecureSkipVerify": { "type": "boolean" }
              }
            }
          }
        },
        "image": { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 1 },
        "resources": { "$ref": "#/$defs/resources" },
        "persistence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string" },
            "storageClass": { "type": "string" }
          }
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "httpPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "nativePort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "username": { "type": "string" },
            "password": { "type": "string" }
          }
        },
        "exporter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "cluster": {
          "type": "object",
          "additionalProperties": false,
          "description": "Distributed-table mode toggle. When enabled, every table becomes a Replicated*MergeTree local + Distributed front pair.",
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 },
            "shards": { "type": "integer", "minimum": 1 },
            "replicas": { "type": "integer", "minimum": 1 },
            "shardingKey": { "type": "string" },
            "keeper": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "external": { "type": "string" }
              }
            }
          }
        },
        "setup": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "$ref": "#/$defs/image" },
            "database": { "type": "boolean" },
            "rawTable": { "type": "boolean" },
            "deadLetterTable": { "type": "boolean" },
            "summaryTable": { "type": "boolean" },
            "materializedView": { "type": "boolean" }
          }
        },
        "nodeSelector": { "$ref": "#/$defs/nodeSelector" },
        "tolerations":  { "$ref": "#/$defs/tolerations" },
        "affinity":     { "$ref": "#/$defs/affinity" },
        "podAnnotations": { "$ref": "#/$defs/annotations" }
      }
    },
    "logstash": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "external": { "$ref": "#/$defs/external" },
        "image": { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 1 },
        "resources": { "$ref": "#/$defs/resources" },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "httpPort":       { "type": "integer", "minimum": 1, "maximum": 65535 },
            "monitoringPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "pipeline": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "workers":    { "type": "integer", "minimum": 1 },
            "batchSize":  { "type": "integer", "minimum": 1 },
            "batchDelay": { "type": "integer", "minimum": 0 }
          }
        },
        "queue": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type":     { "type": "string", "enum": ["memory", "persisted"] },
            "maxBytes": { "type": "string" }
          }
        },
        "clickhouseOutput": {
          "type": "object",
          "additionalProperties": false,
          "description": "Tunables passed to logstash-output-clickhouse for both raw and dead-letter routes.",
          "properties": {
            "flushSize":            { "type": "integer", "minimum": 1 },
            "deadLetterFlushSize":  { "type": "integer", "minimum": 1 },
            "idleFlushTime":        { "type": "integer", "minimum": 1 },
            "automaticRetries":     { "type": "integer", "minimum": 0 },
            "poolMax":              { "type": "integer", "minimum": 1 },
            "chSettings":           { "type": "string" }
          }
        },
        "exporter": { "$ref": "#/$defs/exporter" },
        "nodeSelector": { "$ref": "#/$defs/nodeSelector" },
        "tolerations":  { "$ref": "#/$defs/tolerations" },
        "affinity":     { "$ref": "#/$defs/affinity" },
        "podAnnotations": { "$ref": "#/$defs/annotations" },
        "pdb":          { "$ref": "#/$defs/pdb" }
      }
    },
    "analyzer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":  { "type": "boolean" },
        "image":    { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 1 },
        "port":     { "type": "integer", "minimum": 1, "maximum": 65535 },
        "dynamicBaselines": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cacheTTL":    { "type": "string" },
            "queryWindow": { "type": "string" }
          }
        },
        "stressBaselines": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tookMs":       { "type": "string" },
            "hits":         { "type": "string" },
            "shardsTotal":  { "type": "string" },
            "docsAffected": { "type": "string" }
          }
        },
        "resources": { "$ref": "#/$defs/resources" },
        "nodeSelector": { "$ref": "#/$defs/nodeSelector" },
        "tolerations":  { "$ref": "#/$defs/tolerations" },
        "affinity":     { "$ref": "#/$defs/affinity" },
        "podAnnotations": { "$ref": "#/$defs/annotations" },
        "extraEnv": { "type": "array" },
        "pdb": { "$ref": "#/$defs/pdb" }
      }
    },
    "gateway": {
      "type": "object",
      "additionalProperties": true,
      "description": "Gateway upstream Elasticsearch (the customer's ES being proxied) is configured under gateway.elasticsearch. Gateway untouched by the v2 CH migration."
    },
    "grafana": {
      "type": "object",
      "additionalProperties": true
    },
    "ingress": { "type": "object", "additionalProperties": true },
    "route":   { "type": "object", "additionalProperties": true },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "name":   { "type": "string" },
        "annotations": { "$ref": "#/$defs/annotations" }
      }
    },
    "podSecurityContext": { "type": "object", "additionalProperties": true },
    "securityContext":    { "type": "object", "additionalProperties": true },
    "testImage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "tag":        { "type": "string" }
      }
    },
    "serviceMonitors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":  { "type": "boolean" },
        "labels":   { "$ref": "#/$defs/annotations" },
        "interval": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nameOverride":     { "type": "string" },
    "fullnameOverride": { "type": "string" }
  },
  "$defs": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "tag":        { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": { "type": "object", "additionalProperties": true },
        "limits":   { "type": "object", "additionalProperties": true }
      }
    },
    "exporter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":   { "type": "boolean" },
        "image":     { "$ref": "#/$defs/image" },
        "port":      { "type": "integer", "minimum": 1, "maximum": 65535 },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "external": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "url":     { "type": "string" }
      }
    },
    "annotations":  { "type": "object", "additionalProperties": { "type": "string" } },
    "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
    "tolerations":  { "type": "array" },
    "affinity":     { "type": "object", "additionalProperties": true },
    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":        { "type": "boolean" },
        "minAvailable":   { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    }
  }
}
